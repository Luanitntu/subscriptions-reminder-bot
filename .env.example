# Discord
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/subscriptions_reminder

# Scheduler (24h format)
REMINDER_HOUR=8
REMINDER_MINUTE=30

# App
TIMEZONE=Asia/Ho_Chi_Minh

# Logs (optional) — trỏ sang Railway Volume để log không bị xoá khi redeploy, vd /data/logs
# LOG_DIR=/data/logs
